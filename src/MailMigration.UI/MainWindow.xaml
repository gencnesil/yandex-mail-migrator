<Window x:Class="MailMigration.UI.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mail Migration Desktop" Height="850" Width="1280" MinHeight="720" MinWidth="1080" Background="#0B1120" Foreground="#E5E7EB">
  <Window.Resources>
    <Style TargetType="TextBox"><Setter Property="Margin" Value="0,5,0,12"/><Setter Property="Padding" Value="10,7"/><Setter Property="Background" Value="#111827"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#374151"/></Style>
    <Style TargetType="PasswordBox"><Setter Property="Margin" Value="0,5,0,12"/><Setter Property="Padding" Value="10,7"/><Setter Property="Background" Value="#111827"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderBrush" Value="#374151"/></Style>
    <Style TargetType="Button"><Setter Property="Margin" Value="0,0,10,0"/><Setter Property="Padding" Value="16,9"/><Setter Property="Background" Value="#2563EB"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style TargetType="GroupBox"><Setter Property="Margin" Value="0,0,14,14"/><Setter Property="Padding" Value="15"/><Setter Property="Foreground" Value="#D1D5DB"/><Setter Property="BorderBrush" Value="#374151"/></Style>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <Border Background="#111827" Padding="22"><StackPanel>
      <TextBlock Text="MAIL MIGRATION" FontSize="19" FontWeight="Bold" Foreground="#60A5FA" Margin="0,5,0,28"/>
      <TextBlock Text="●  Yeni taşıma" FontWeight="SemiBold" Margin="0,0,0,18"/>
      <TextBlock Text="○  Bağlantı testi" Margin="0,0,0,18"/><TextBlock Text="○  Kaynak analizi" Margin="0,0,0,18"/><TextBlock Text="○  Klasör eşleme" Margin="0,0,0,18"/>
      <TextBlock Text="○  Aktif taşıma" Margin="0,0,0,18"/><TextBlock Text="○  Tamamlanan işler" Margin="0,0,0,18"/><TextBlock Text="○  Başarısız mesajlar" Margin="0,0,0,18"/>
      <TextBlock Text="○  Loglar ve raporlar" Margin="0,0,0,18"/><TextBlock Text="○  Ayarlar"/>
    </StackPanel></Border>
    <Grid Grid.Column="1" Margin="26,20">
      <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
      <StackPanel><TextBlock Text="Yeni e-posta taşıma işi" FontSize="26" FontWeight="SemiBold"/><TextBlock Text="IMAP üzerinden, klasör ve MIME yapısını koruyarak güvenli aktarım" Foreground="#94A3B8" Margin="0,5,0,20"/></StackPanel>
      <TabControl Grid.Row="1" Background="#0B1120" Foreground="#D1D5DB" BorderBrush="#374151">
        <TabItem Header="1  Hesaplar"><ScrollViewer VerticalScrollBarVisibility="Auto"><Grid Margin="18"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
          <GroupBox Header="Kaynak hesap"><StackPanel><TextBlock Text="IMAP sunucusu"/><TextBox Text="{Binding SourceHost, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Port"/><TextBox Text="{Binding SourcePort}"/><TextBlock Text="E-posta"/><TextBox Text="{Binding SourceEmail, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Kullanıcı adı"/><TextBox Text="{Binding SourceUsername, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Şifre"/><PasswordBox x:Name="SourcePassword"/></StackPanel></GroupBox>
          <GroupBox Grid.Column="1" Header="Hedef hesap"><StackPanel><TextBlock Text="IMAP sunucusu"/><TextBox Text="{Binding TargetHost, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Port"/><TextBox Text="{Binding TargetPort}"/><TextBlock Text="E-posta"/><TextBox Text="{Binding TargetEmail, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Kullanıcı adı"/><TextBox Text="{Binding TargetUsername, UpdateSourceTrigger=PropertyChanged}"/><TextBlock Text="Şifre"/><PasswordBox x:Name="TargetPassword"/></StackPanel></GroupBox>
        </Grid></ScrollViewer></TabItem>
        <TabItem Header="2  Bağlantı testi"><DataGrid ItemsSource="{Binding ConnectionResults}" AutoGenerateColumns="False" IsReadOnly="True" Background="#111827" Foreground="White" RowBackground="#111827" AlternatingRowBackground="#172033" Margin="15"><DataGrid.Columns><DataGridTextColumn Header="Test" Binding="{Binding Kind}" Width="180"/><DataGridCheckBoxColumn Header="Başarılı" Binding="{Binding Success}" Width="90"/><DataGridTextColumn Header="Süre" Binding="{Binding Duration}" Width="120"/><DataGridTextColumn Header="TLS" Binding="{Binding TlsVersion}" Width="100"/><DataGridTextColumn Header="Sunucu cevabı / hata" Binding="{Binding ServerResponse}" Width="*"/></DataGrid.Columns></DataGrid></TabItem>
        <TabItem Header="3  Klasör eşleme"><DataGrid ItemsSource="{Binding Mappings}" AutoGenerateColumns="False" Background="#111827" Foreground="White" RowBackground="#111827" Margin="15"><DataGrid.Columns><DataGridTextColumn Header="Kaynak" Binding="{Binding SourcePath}" Width="*"/><DataGridTextColumn Header="Hedef" Binding="{Binding TargetPath}" Width="*"/><DataGridTextColumn Header="SpecialUse" Binding="{Binding SpecialUse}" Width="140"/></DataGrid.Columns></DataGrid></TabItem>
        <TabItem Header="4  Taşıma"><StackPanel Margin="28"><TextBlock Text="Aktif taşıma" FontSize="22" FontWeight="SemiBold"/><ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Height="18" Margin="0,18,0,8" Foreground="#22C55E"/><TextBlock Text="{Binding ProgressPercent, Mode=OneWay, StringFormat={}{0:N1}%}" FontSize="18"/>
          <UniformGrid Columns="6" Margin="0,25"><StackPanel><TextBlock Text="İşlenen" Foreground="#94A3B8"/><TextBlock Text="{Binding Processed}" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="Toplam" Foreground="#94A3B8"/><TextBlock Text="{Binding Total}" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="Başarılı" Foreground="#94A3B8"/><TextBlock Text="{Binding Completed}" FontSize="20" Foreground="#22C55E"/></StackPanel><StackPanel><TextBlock Text="Atlanan" Foreground="#94A3B8"/><TextBlock Text="{Binding Skipped}" FontSize="20"/></StackPanel><StackPanel><TextBlock Text="Başarısız" Foreground="#94A3B8"/><TextBlock Text="{Binding Failed}" FontSize="20" Foreground="#EF4444"/></StackPanel><StackPanel><TextBlock Text="Bayt" Foreground="#94A3B8"/><TextBlock Text="{Binding TransferredBytes, StringFormat=N0}" FontSize="20"/></StackPanel></UniformGrid>
          <WrapPanel><TextBlock Text="Batch" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Text="{Binding BatchSize}" Width="80" Margin="0,0,20,0"/><TextBlock Text="Worker (1–10)" VerticalAlignment="Center" Margin="0,0,8,0"/><TextBox Text="{Binding Parallelism}" Width="80"/></WrapPanel>
        </StackPanel></TabItem>
      </TabControl>
      <Grid Grid.Row="2" Margin="0,16,0,0"><Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="{Binding Status}" Foreground="#93C5FD" TextWrapping="Wrap" Margin="0,0,0,14"/><WrapPanel Grid.Row="1"><Button Content="Bağlantıları test et" Click="Test_Click"/><Button Content="Posta kutularını analiz et" Command="{Binding AnalyzeCommand}"/><Button Content="Taşımayı başlat" Command="{Binding StartCommand}" Background="#16A34A"/><Button Content="Duraklat" Command="{Binding PauseCommand}" Background="#D97706"/><Button Content="Devam et" Command="{Binding ResumeCommand}"/><Button Content="Güvenli durdur" Command="{Binding CancelCommand}" Background="#DC2626"/></WrapPanel></Grid>
    </Grid>
  </Grid>
</Window>
